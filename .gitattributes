# Normalize line endings: store text as LF in the repo, check out native on each platform.
* text=auto

# Windows scripts are most predictable with CRLF in the working tree.
*.ps1  text eol=crlf
*.bat  text eol=crlf
*.cmd  text eol=crlf

# Binaries (never normalize).
*.exe  binary
*.dll  binary
*.zip  binary
*.png  binary
*.jpg  binary
*.ico  binary
